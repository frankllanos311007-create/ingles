{
    "version": 2,
    "cleanUrls": true,
    "routes": [
        {
            "src": "/style.css",
            "dest": "/style.css"
        },
        {
            "src": "/scripts.js",
            "dest": "/scripts.js"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}